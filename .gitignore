# ═══════════════════════════════════════════════════════════════
# .gitignore — DocMind Enterprise RAG Q&A
# ═══════════════════════════════════════════════════════════════

# ── Python ──────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ─────────────────────────────────────────
venv/
.venv/
env/
ENV/
.env

# ─── Keep only the example file ──────────────────────────────────
!.env.example

# ── Secrets (never commit) ───────────────────────────────────────
*.key
*.pem
*.cert
secrets/

# ── Uploaded documents & vector indices (runtime data) ───────────
uploads/
vector_stores/

# ── Test artifacts ────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.coveragerc

# ── IDE ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.cursor/
*.code-workspace

# ── Docker overrides (local tweaks only) ─────────────────────────
docker-compose.override.yml
.docker/

# ── OS files ─────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────────────
*.log
logs/
*.log.*

# ── Node (if frontend tooling is added later) ────────────────────
node_modules/
npm-debug.log*
yarn-error.log*

# ── Temp ─────────────────────────────────────────────────────────
tmp/
temp/
.tmp/

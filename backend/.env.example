# ═══════════════════════════════════════════════════════════════
# DocMind Backend — Environment Variables
# For LOCAL DEVELOPMENT only (without Docker)
# Copy this → .env in this same directory (backend/)
# ═══════════════════════════════════════════════════════════════

# ─── REQUIRED ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here

# ─── OPTIONAL: Model ───────────────────────────────────────────
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ─── OPTIONAL: RAG pipeline ────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5
LLM_TEMPERATURE=0.1

# ─── OPTIONAL: File limits ─────────────────────────────────────
MAX_FILE_SIZE_MB=10

# ─── OPTIONAL: App ─────────────────────────────────────────────
APP_ENV=development
